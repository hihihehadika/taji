{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Taji",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.taji"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.taji"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.taji",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.taji",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.taji",
          "match": "\\b(jika|lainnya|selama|untuk|kembalikan|berhenti|lanjut|coba|tangkap|lemparkan|dan|atau|bukan)\\b"
        },
        {
          "name": "keyword.declaration.taji",
          "match": "\\b(misalkan|fungsi)\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.taji",
      "match": "\\b(benar|salah|kosong)\\b"
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.taji",
          "match": "\\b(cetak|panjang|tipe|ambil_web|ke_json|dari_json|dorong|petakan|saring|waktu_sekarang|acak)\\b"
        },
        {
          "name": "entity.name.function.taji",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.taji",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "operators": {
      "name": "keyword.operator.taji",
      "match": "(\\+|-|\\*|/|%|==|!=|<|>|<=|>=|=|=>|\\+=|-=|\\*=|/=)"
    }
  },
  "scopeName": "source.taji"
}